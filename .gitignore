# Stray npm lockfile — this is a pnpm workspace
package-lock.json

# .atl cache files (skill-registry.md itself IS committed)
.atl/.*.cache.json

# pi.dev local runtime state (per-cwd settings, session data)
.pi/

# SQLite databases (per-agent runtime state, never committed)
*.db
*.db-wal
*.db-shm
