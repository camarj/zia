{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npx skillsadd:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(gentle-ai:*)",
      "Bash(engram:*)",
      "Edit",
      "Write",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.ts|*.tsx) pnpm typecheck ;; esac"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *agents/*/profile.yaml) pnpm --filter @zia/core validate-ficha || true ;; esac"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "c=$(jq -r '.tool_input.command // empty'); if printf '%s' \"$c\" | grep -Eq 'git[[:space:]]+push.*([[:space:]]|:)main([[:space:]]|$)'; then echo 'Direct push to main blocked. Open a PR.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
